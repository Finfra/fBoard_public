    "prefs.advanced.reset.desc" : {
      "comment" : "초기화 설명",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setzt alle Einstellungen und Benutzer-Voreinstellungen auf den Standardzustand zurück. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resets all settings and user presets to their default state. This action cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restablece todos los ajustes y preajustes de usuario a su estado predeterminado. Esta acción no se puede deshacer."
